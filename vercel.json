{
  "version": 2,
  "builds": [
    {
      "src": "entry_points/vercel_handler.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/styles.css",
      "destination": "/styles.css"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/api/(.*)",
      "destination": "/entry_points/vercel_handler.py"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}